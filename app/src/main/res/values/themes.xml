<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CheckList_App" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/success</item>
        <item name="colorError">@color/error</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="android:colorBackground">@color/background</item>

        <!-- Status Bar -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- Typography & Components -->
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.CheckList.Headline</item>
        <item name="textInputStyle">@style/Widget.CheckList.TextInput</item>
        <item name="materialButtonStyle">@style/Widget.CheckList.Button</item>
        <item name="cardViewStyle">@style/Widget.CheckList.Card</item>
    </style>

    <style name="TextAppearance.CheckList.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="Widget.CheckList.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="startIconTint">@color/primary</item>
        <item name="cornerRadius">10dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

    <style name="Widget.CheckList.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="elevation">2dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
    </style>

    <style name="Widget.CheckList.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardElevation">3dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="contentPadding">12dp</item>
    </style>
</resources>