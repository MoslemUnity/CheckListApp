<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:layoutDirection="rtl">

        <!-- ردیف اول: آیکون، عنوان کار، دکمه حذف -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivCheckIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/checkbox_on_background"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tvTaskText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="4dp" />

            <ImageButton
                android:id="@+id/btnDeleteHistory"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/error"
                android:padding="4dp" />

        </LinearLayout>

        <!-- ردیف دوم: نمایش تاریخ و ساعت -->
        <!-- ✅ تغییر مهم: استفاده از text_secondary که در فایل رنگی شما موجود است -->
        <TextView
            android:id="@+id/tvTaskDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="34dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="end" />

    </LinearLayout>
</androidx.cardview.widget.CardView>